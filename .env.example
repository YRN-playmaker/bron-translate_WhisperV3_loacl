# ----------------------------------------------------------------------------
# BroN-translate (Local Edition) — configuration
# Copy this file to ".env" and fill in your values. Never commit your real .env.
# ----------------------------------------------------------------------------

# --- Translation (DeepSeek) -------------------------------------------------
# Get a key at https://platform.deepseek.com/. Transcription still works
# without it, but translation will be disabled until you set this.
#输入你deepseek的key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- ASR (faster-whisper) ---------------------------------------------------
# WHISPER_MODEL:
#   large-v3        -> default. Best accuracy, full 32-layer decoder.
#   large-v3-turbo  -> ~4x faster, distilled 4-layer decoder. Slightly lower
#                      accuracy; use it only if you specifically want speed.
#模型位置
#WHISPER_MODEL=large-v3
WHISPER_MODEL=./model/whisper-large-v3
# Device + compute type.
#   GPU (recommended): WHISPER_DEVICE=cuda  WHISPER_COMPUTE_TYPE=float16
#   Low VRAM:          WHISPER_DEVICE=cuda  WHISPER_COMPUTE_TYPE=int8_float16
#   CPU only (slow):   WHISPER_DEVICE=cpu   WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
#精度，建议默认，显卡好的可以跑float32

# --- Live preview (Vosk, optional) ------------------------------------------
# Only loaded when a client turns on the "live preview" toggle. Download a
# model from https://alphacephei.com/vosk/models and unzip it here.
VOSK_MODEL_PATH=model/vosk-model-small-en-us
#模型位置
# --- Server -----------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
AUTO_OPEN_BROWSER=1
